# Server environment
NODE_ENV=development
PORT=4000

# Database Configuration (PostgreSQL)
# Format: postgres://username:password@host:port/database_name
DATABASE_URL=postgres://postgres:b65dc7f1ea0d499b96f799014ab62ca9@localhost:5432/worldr_db

# Caching Configuration (Redis)
# Format: redis://host:port
REDIS_URL=redis://localhost:6379

# JWT Token secrets (Ensure these are long, random secure strings in production)
JWT_ACCESS_SECRET=your_32_character_jwt_access_secret_string_here_12345
JWT_REFRESH_SECRET=your_32_character_jwt_refresh_secret_string_here_12345

# Frontend env
