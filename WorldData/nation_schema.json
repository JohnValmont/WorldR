{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nation",
  "description": "Standard structure every nation must follow in WORLDr",
  "type": "object",
  "properties": {
    "identity": {
      "type": "object",
      "required": ["nation_id", "name", "continent", "culture", "capital", "government_type", "flag_path", "map_color", "is_playable", "launch_status"],
      "properties": {
        "nation_id": { "type": "string" },
        "name": { "type": "string" },
        "continent": { "type": "string", "enum": ["Varelia", "Azhara", "Norvane", "Solkar"] },
        "culture": { "type": "string", "enum": ["Varelian", "Azharan", "Norvanian", "Solkaran"] },
        "capital": { "type": "string" },
        "government_type": { "type": "string" },
        "flag_path": { "type": "string" },
        "map_color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "is_playable": { "type": "boolean" },
        "launch_status": { "type": "string" }
      }
    },
    "population": {
      "type": "object",
      "required": ["urban_population", "rural_population", "total_population", "urbanization_rate"],
      "properties": {
        "urban_population": { "type": "integer", "minimum": 0 },
        "rural_population": { "type": "integer", "minimum": 0 },
        "total_population": { "type": "integer", "minimum": 0 },
        "urbanization_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "economy": {
      "type": "object",
      "required": ["gdp", "gdp_per_capita", "currency", "development_level", "main_industries", "resource_profile"],
      "properties": {
        "gdp": { "type": "integer", "minimum": 0 },
        "gdp_per_capita": { "type": "number", "minimum": 0 },
        "currency": { "type": "string" },
        "development_level": { "type": "string" },
        "main_industries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resource_profile": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "geography": {
      "type": "object",
      "properties": {
        "total_area_km2": { "type": "number", "minimum": 0 },
        "land_area_km2": { "type": "number", "minimum": 0 },
        "water_area_km2": { "type": "number", "minimum": 0 },
        "climate_zones": { "type": "array", "items": { "type": "string" } },
        "terrain_types": { "type": "array", "items": { "type": "string" } },
        "highest_point": { "type": "string" },
        "bordering_nations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "government": {
      "type": "object",
      "properties": {
        "ruling_party": { "type": "string" },
        "head_of_state": { "type": "string" },
        "legislature": { "type": "string" },
        "political_stability": { "type": "number", "minimum": 0, "maximum": 100 },
        "laws": { "type": "array", "items": { "type": "string" } },
        "administrative_divisions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "military": {
      "type": "object",
      "properties": {
        "total_personnel": { "type": "integer", "minimum": 0 },
        "active_duty": { "type": "integer", "minimum": 0 },
        "reserve_duty": { "type": "integer", "minimum": 0 },
        "branches": {
          "type": "object",
          "properties": {
            "army": { "type": "object" },
            "navy": { "type": "object" },
            "air_force": { "type": "object" }
          }
        },
        "budget_acr": { "type": "number", "minimum": 0 },
        "nuclear_capabilities": { "type": "boolean" }
      }
    },
    "parties": {
      "type": "object",
      "properties": {
        "political_parties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "party_id": { "type": "string" },
              "name": { "type": "string" },
              "ideology": { "type": "string" },
              "seats_held": { "type": "integer" },
              "total_seats": { "type": "integer" },
              "popularity_pct": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "diplomacy": {
      "type": "object",
      "properties": {
        "alliances": { "type": "array", "items": { "type": "string" } },
        "rivalries": { "type": "array", "items": { "type": "string" } },
        "trade_agreements": { "type": "array", "items": { "type": "string" } },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "target_nation_id": { "type": "string" },
              "relation_value": { "type": "integer", "minimum": -100, "maximum": 100 },
              "status": { "type": "string" }
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "natural_resources": { "type": "array", "items": { "type": "string" } },
        "production": { "type": "object" },
        "consumption": { "type": "object" },
        "stockpiles": { "type": "object" }
      }
    },
    "map": {
      "type": "object",
      "properties": {
        "regions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "region_id": { "type": "string" },
              "name": { "type": "string" },
              "coordinates": { "type": "array" }
            }
          }
        },
        "color": { "type": "string" }
      }
    }
  }
}
